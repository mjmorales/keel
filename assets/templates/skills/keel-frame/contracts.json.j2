{# Machine-readable contract graph. Generated by Keel. #}
{
  "project": "{{ project_name }}",
  "inception_date": "{{ inception_date }}",
  "segments": [
{% for seg in segments %}
    {
      "name": "{{ seg.name }}",
      "path": "{{ seg.path }}",
      "language": "{{ seg.language }}",
      "constraints": [{% for c in seg.constraints %}"{{ c }}"{% if not loop.last %}, {% endif %}{% endfor %}],
      "owns": [{% for o in seg.owns %}"{{ o }}"{% if not loop.last %}, {% endif %}{% endfor %}],
      "patterns": [{% for p in seg.patterns %}{"name": "{{ p.name }}", "purpose": "{{ p.purpose }}"}{% if not loop.last %}, {% endif %}{% endfor %}]
    }{% if not loop.last %},{% endif %}

{% endfor %}
  ],
  "forbidden_imports": [
{% for fi in forbidden_imports %}
    {"segment": "{{ fi.segment }}", "must_not_import": "{{ fi.must_not_import }}", "reason": "{{ fi.reason }}"}{% if not loop.last %},{% endif %}

{% endfor %}
  ],
  "vocabulary": [
{% for v in vocabulary %}
    {"term": "{{ v.term }}", "kind": "{{ v.kind }}", "owner": "{{ v.owner }}"}{% if not loop.last %},{% endif %}

{% endfor %}
  ]
}
