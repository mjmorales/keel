#!/usr/bin/env bash
# Keel pre-commit hook. Generated by Keel.
# Checks staged files against architectural contracts.

set -euo pipefail

if ! command -v keel &>/dev/null; then
    echo "keel: CLI not found. Install with: pipx install keel-cli" >&2
    echo "keel: Skipping contract checks." >&2
    exit 0
fi

keel check --staged
